# Copy this file to .env and fill in the values you need.
# Scripts in this repo source `${REPO_ROOT}/.env` automatically.

# --- Agent API keys -----------------------------------------------------------
# Used by the auditor agent (`agent_cli`). The specific variable consumed is
# determined by `api_key_env` in each benchmark config (e.g. ANTHROPIC_API_KEY,
# OPENAI_API_KEY). Set whichever your selected agent needs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Required when generating trajectories with Claude Code via Harbor.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Pipeline output ----------------------------------------------------------
# Root dir where audit outputs (benchmark + task audits, evidence, reports) land.
# Defaults to ${REPO_ROOT}/data/multi_domain_all when unset.
MULTI_DOMAIN_AUDIT_RUN_DIR=

# Toggle prompt-level debug logging for the auditor agent (0/1).
BENCH_AUDIT_DEBUG_PROMPTS=0

# --- Benchmark data locations -------------------------------------------------
# Where ABA expects (and writes) per-benchmark repos and datasets. Referenced
# from configs/**/*.yaml as ${BENCHMARK_REPOS_DIR}/<benchmark>/{repo,data}.
BENCHMARK_REPOS_DIR=

# Harbor-managed dataset cache (used by configs/harbor/*.yaml and
# configs/tb2/*.yaml). Set to wherever Harbor downloads datasets.
HARBOR_DATASETS_DIR=

# Output dir for Harbor job runs (trajectories). Used by
# configs/tb2/eval_claude_code_sonnet.yaml as ${TB2_JOBS_DIR}.
TB2_JOBS_DIR=

# Root of the SWE-bench data + results tree (configs/swe_bench/*.yaml).
SWEBENCH_DIR=

# --- BenchGuard eval (benchmarks/benchguard/run_eval.sh) ----------------------
# Gemini key used by the LLM-judge matcher. Either GEMINI_API_KEY or GOOGLE_API
# works; the script remaps GOOGLE_API -> GEMINI_API_KEY.
GEMINI_API_KEY=
# GOOGLE_API=
# JUDGE_MODEL=gemini/gemini-3-flash-preview
# JUDGE_MAX_TOKENS=8192
